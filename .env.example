# mission-bullet environment configuration. Copy to .env and fill in.

# --- LLM provider ---
#
# mission-bullet auto-picks a provider in this order (first match wins):
#   1. MISSION_BULLET_PROVIDER=<kind>   (explicit override)
#   2. OLLAMA_BASE_URL reachable         (best privacy — local inference)
#   3. OPENROUTER_API_KEY set            (cloud, cheap)
#   4. `claude` CLI on PATH              (uses your Claude Code subscription)
#
# Leave everything commented out and mission-bullet will default to #4
# if you have Claude Code installed — no setup needed.

# Explicit override: "claude" | "openrouter" | "ollama"
# MISSION_BULLET_PROVIDER=openrouter

# Ollama (local — preferred for personal data when hardware allows):
# OLLAMA_BASE_URL=http://localhost:11434
# MISSION_BULLET_LLM_MODEL=qwen2.5:7b

# OpenRouter (cloud):
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# MISSION_BULLET_LLM_MODEL=anthropic/claude-sonnet-4-6

# Claude Code CLI: no env needed — just `claude` on PATH.
# Optional model override (otherwise uses Claude Code's configured default):
# MISSION_BULLET_LLM_MODEL=sonnet

# --- Model override for `bullet claude-note --ask` specifically ---
#
# `claude-note --ask` (and its `bullet ask` alias) default to a free
# OpenRouter model (google/gemma-4-31b-it:free) so casual commentary
# doesn't burn credits. Override this if you want a stronger model
# by default — e.g. anthropic/claude-sonnet-4-6 via OpenRouter
# credits, or opus for the highest quality.
# MISSION_BULLET_CLAUDE_NOTE_MODEL=google/gemma-4-31b-it:free

# --- Editor for `bullet today` (opens the daily entry file) ---
# Defaults to $EDITOR or notepad/nano if unset. Override if you prefer:
# MISSION_BULLET_EDITOR=code --wait
